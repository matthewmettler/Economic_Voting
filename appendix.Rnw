<<wave3>>=
df1 <- w3 %>%
  mutate(
    pidf = case_when(
      pidf %in% c("5", "6", "7") ~ "Rep",
      pidf %in% c("1", "2", "3") ~ "Dem",
      pidf == c("4")              ~ "Ind",
      #pidf == "8"                ~ "oth",
      TRUE                       ~ NA_character_
    )
  ) %>%
  filter(!is.na(weight_w3), weight_w3 > 0)

# first-stage complete-case sample
df_soc1 <- df1 %>%
  filter(
    complete.cases(
      soc_bt, pidf, econ_ptbias, econ_resid,
      age, black, hispanic, female, weight_w3
    )
  )

# vote sample
df_vote1 <- df_soc1 %>%
  filter(TWVOTE2_w3 < 3) %>%
  mutate(
    vharris = ifelse(TWVOTE2_w3 == 1, 1, 0),
  ) %>%
  filter(
    complete.cases(
      vharris, soc_bt, pidf,
      age, black, hispanic, female, weight_w3
    )
  )

df_vote1 <-df_vote1 %>%
  mutate(
    weight_w3 = weight_w3 / mean(weight_w3, na.rm = TRUE))

# -------------------------
# 2) Survey-weighted models
# -------------------------
des_soc1 <- survey::svydesign(
  ids = ~1,
  weights = ~weight_w3,
  data = df_soc1
)

m_soc <- survey::svyglm(
  soc_bt ~ pidf * (econ_ptbias + econ_resid) + age + black + hispanic + female,
  design = des_soc1
)

m_socD <- survey::svyglm(
  soc_bt ~ pidf * (PRB_D + RR_D) + age + black + hispanic + female,
  design = des_soc1
)

des_vote1 <- survey::svydesign(
  ids = ~1,
  weights = ~weight_w3,
  data = df_vote1
)

m_vote <- survey::svyglm(
  vharris ~ soc_bt * pidf + age + black + hispanic + female,
  design = des_vote1,
  family = quasibinomial())

@



