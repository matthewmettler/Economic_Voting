<<>>=
make_hist <- function(data, var, xlab_text, fill_color, y_max = 425) {
  ggplot(data, aes(x = .data[[var]])) +
    geom_bar(fill = fill_color, color = "black") +
    xlab(xlab_text) +
    ylab("Count") +
    coord_cartesian(ylim = c(0, y_max)) +
    theme_bw()
}

make_wave_panel <- function(data, wave_title, y_max = 425) {
  
  # All
  all_bt <- make_hist(data, "soc_bt", "Sociotropic perception: Biden - Trump", "grey30", y_max)
  all_b  <- make_hist(data, "soc_b",  "Sociotropic perception: Biden", "grey30", y_max)
  all_t  <- make_hist(data, "soc_t",  "Sociotropic perception: Trump", "grey30", y_max)
  row_all <- ggarrange(all_bt, all_b, all_t, ncol = 3)
  row_all <- annotate_figure(row_all, left = text_grob("All Respondents", rot = 90, face = "bold"))
  
  # Democrats
  dem_bt <- make_hist(filter(data, pidf == "Dem"), "soc_bt", "Sociotropic perception: Biden - Trump", "blue3", y_max)
  dem_b  <- make_hist(filter(data, pidf == "Dem"), "soc_b",  "Sociotropic perception: Biden", "blue3", y_max)
  dem_t  <- make_hist(filter(data, pidf == "Dem"), "soc_t",  "Sociotropic perception: Trump", "blue3", y_max)
  row_dem <- ggarrange(dem_bt, dem_b, dem_t, ncol = 3)
  row_dem <- annotate_figure(row_dem, left = text_grob("Democrats", rot = 90, face = "bold"))
  
  # Independents
  ind_bt <- make_hist(filter(data, pidf == "Ind"), "soc_bt", "Sociotropic perception: Biden - Trump", "grey60", y_max)
  ind_b  <- make_hist(filter(data, pidf == "Ind"), "soc_b",  "Sociotropic perception: Biden", "grey60", y_max)
  ind_t  <- make_hist(filter(data, pidf == "Ind"), "soc_t",  "Sociotropic perception: Trump", "grey60", y_max)
  row_ind <- ggarrange(ind_bt, ind_b, ind_t, ncol = 3)
  row_ind <- annotate_figure(row_ind, left = text_grob("Independents", rot = 90, face = "bold"))
  
  # Republicans
  rep_bt <- make_hist(filter(data, pidf == "Rep"), "soc_bt", "Sociotropic perception: Biden - Trump", "red3", y_max)
  rep_b  <- make_hist(filter(data, pidf == "Rep"), "soc_b",  "Sociotropic perception: Biden", "red3", y_max)
  rep_t  <- make_hist(filter(data, pidf == "Rep"), "soc_t",  "Sociotropic perception: Trump", "red3", y_max)
  row_rep <- ggarrange(rep_bt, rep_b, rep_t, ncol = 3)
  row_rep <- annotate_figure(row_rep, left = text_grob("Republicans", rot = 90, face = "bold"))
  
  final_wave <- ggarrange(
    row_all,
    row_dem,
    row_ind,
    row_rep,
    ncol = 1,
    nrow = 4
  )
  
  annotate_figure(
    final_wave,
    top = text_grob(wave_title, face = "bold", size = 16)
  )
}


wave2_plot <- make_wave_panel(df_soc, "Wave 2")
wave3_plot <- make_wave_panel(df_soc1, "Wave 3")

ggsave("wave2_sociotropic_histograms.pdf", wave2_plot, width = 10, height = 14)
ggsave("wave3_sociotropic_histograms.pdf", wave3_plot, width = 10, height = 14)

