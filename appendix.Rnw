<<>>=


vars <- c("soc_b","soc_t","soc_bt", "econ_ptbias", "econ_resid", "PRB_D", "RR_D",
          "age", "black", "hispanic", "female")

var_labels <- c(
  soc_b = "Sociotropic Perception Biden",
  soc_t = "Sociotropic Perception Trump",
  soc_bt      = "Sociotropic Perception",
  econ_ptbias = "Partisan Response Bias",
  econ_resid  = "Residual Response",
  PRB_D       = "Partisan Response Bias (Discrete)",
  RR_D        = "Residual Response (Discrete)",
  age         = "Age",
  black       = "Black",
  hispanic    = "Hispanic",
  female      = "Female"
)

make_weighted_tab <- function(data, vars, weight_var = "weight_w2") {
  
  df <- data %>%
    dplyr::select(all_of(c(vars, weight_var))) 
  
  des <- survey::svydesign(
    ids = ~1,
    weights = as.formula(paste0("~", weight_var)),
    data = df
  )
  
  means <- survey::svymean(
    as.formula(paste0("~", paste(vars, collapse = " + "))),
    design = des,
    na.rm = TRUE
  )
  
  vars_svy <- survey::svyvar(
    as.formula(paste0("~", paste(vars, collapse = " + "))),
    design = des,
    na.rm = TRUE
  )
  
  tibble(
    Variable = vars,
    mean = as.numeric(coef(means)),
    sd   = sqrt(diag(as.matrix(vars_svy))),
    min  = map_dbl(vars, ~ min(df[[.x]], na.rm = TRUE)),
    max  = map_dbl(vars, ~ max(df[[.x]], na.rm = TRUE))
  ) %>%
    mutate(
      Variable = dplyr::recode(Variable, !!!var_labels)
    ) %>%
    mutate(
      across(c(mean, sd, min, max), ~ round(.x, 2))
    )
}

tab_all <- make_weighted_tab(df_soc, vars, "weight_w2")

tab_dem <- df_soc %>%
  filter(pidf == "Dem") %>%
  make_weighted_tab(vars = vars, weight_var = "weight_w2")

tab_rep <- df_soc %>%
  filter(pidf == "Rep") %>%
  make_weighted_tab(vars = vars, weight_var = "weight_w2")

tab_ind <- df_soc %>%
  filter(pidf == "Ind") %>%
  make_weighted_tab(vars = vars, weight_var = "weight_w2")
