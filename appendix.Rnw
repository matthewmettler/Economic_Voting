<<>>=
coef_table_zadr <- function(fit) {

  pick <- function(x, nms) {
    for (nm in nms) if (!is.null(x[[nm]])) return(x[[nm]])
    NULL
  }

  be <- pick(fit, c("be", "beta", "coef", "coefficients"))
  se <- pick(fit, c("seb", "se", "sebe", "se_beta", "se.coef"))

  if (is.null(be)) stop("Can't find coefficients in fit (tried: be, beta, coef, coefficients).")
  if (is.null(se)) stop("Can't find standard errors in fit (tried: seb, se, sebe, se_beta, se.coef).")

  be <- as.array(be)
  se <- as.array(se)

  if (!all(dim(be) == dim(se))) {
    stop("Coefficient and SE objects have different dimensions. Inspect str(fit$be) and str(fit$seb).")
  }

  dnb <- dimnames(be)
  if (is.null(dnb)) {
    dnb <- lapply(dim(be), function(n) paste0("d", seq_len(n)))
    dimnames(be) <- dnb
    dimnames(se) <- dnb
  }

  out <- as.data.frame(as.table(be), stringsAsFactors = FALSE)
  names(out) <- c(paste0("Dim", seq_len(ncol(out) - 1)), "Estimate")

  out$Std_Error <- as.vector(se)
  out$Z         <- out$Estimate / out$Std_Error
  out$P_value   <- 2 * pnorm(-abs(out$Z))

  out
}




comp_cols <- c("econ_acc", "econ_ptbias", "econ_resid")
pred_cols <- c("currevents", "demdum", "affpolr", "affpold")

dfz <- w2[, c(comp_cols, pred_cols)]
dfz <- dfz[complete.cases(dfz), ]

Y <- as.matrix(dfz[, comp_cols])
X <- data.frame(dfz[, pred_cols])

fit_h <- Compositional::zadr(y = Y, x = X, con = TRUE)
tab_h <- coef_table_zadr(fit_h)

colnames(tab_h) <- c("Variable", "Component", "Estimate", "Std. error", "Z-score", "P-value")

tab_h$Variable <- dplyr::recode(
  tab_h$Variable,
  "(Intercept)" = "Intercept",
  "Intercept"   = "Intercept",
  "currevents"  = "Current events",
  "demdum"      = "Democrat",
  "affpolr"     = "Affective polarization (Republican)",
  "affpold"     = "Affective polarization (Democratic)"
)

tab_h$Component <- dplyr::recode(
  tab_h$Component,
  "econ_acc"    = "Judgmental accuracy",
  "econ_ptbias" = "Partisan response bias",
  "econ_resid"  = "Residual response"
)

cat("\\begin{table}[H]\n")
cat("\\centering\n")
cat("\\normalsize\n")
cat("\\caption{ZADR coefficients}\n")
cat("\\label{tab:zadr_coef}\n")
cat("\\resizebox{\\linewidth}{!}{%\n")

summary_tab_h <- xtable(tab_h, digits = c(0, 0, 0, 2, 2, 2, 3))
print(summary_tab_h, include.rownames = FALSE, floating = FALSE, comment = FALSE)

cat("}\n")
cat("\\end{table}\n")
@








