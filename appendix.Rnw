tab_all <- make_weighted_tab(df_soc1, vars, "weight_w3")

tab_dem <- df_soc1 %>%
  filter(pidf == "Dem") %>%
  make_weighted_tab(vars = vars, weight_var = "weight_w3")

tab_rep <- df_soc1 %>%
  filter(pidf == "Rep") %>%
  make_weighted_tab(vars = vars, weight_var = "weight_w3")

tab_ind <- df_soc1 %>%
  filter(pidf == "Ind") %>%
  make_weighted_tab(vars = vars, weight_var = "weight_w3")
cat("\\begin{table}[H]\n")
cat("\\centering\n")
cat("\\normalsize\n")
cat("\\caption{Weighted Summary Statistics Wave 3}\n")
cat("\\label{tab:summary_stats}\n")
# Row 1
cat("\\begin{minipage}[t]{0.48\\linewidth}\n")
cat("\\centering\n")
cat("\\textbf{All Respondents}\\\\[0.5em]\n")
summary_tab_all <- xtable(tab_all, digits = c(0, 0, 2, 2, 2, 2))
cat("\\resizebox{\\linewidth}{!}{%\n")
print(summary_tab_all, include.rownames = FALSE, floating = FALSE, comment = FALSE)
cat("}\n")
cat("\\end{minipage}\n")
cat("\\hfill\n")

cat("\\begin{minipage}[t]{0.48\\linewidth}\n")
cat("\\centering\n")
cat("\\textbf{Democrats}\\\\[0.5em]\n")
summary_tab_dem <- xtable(tab_dem, digits = c(0, 0, 2, 2, 2, 2))
cat("\\resizebox{\\linewidth}{!}{%\n")
print(summary_tab_dem, include.rownames = FALSE, floating = FALSE, comment = FALSE)
cat("}\n")
cat("\\end{minipage}\n")

cat("\\vspace{2em}\n")

# Row 2
cat("\\begin{minipage}[t]{0.48\\linewidth}\n")
cat("\\centering\n")
cat("\\textbf{Republicans}\\\\[0.5em]\n")
summary_tab_rep <- xtable(tab_rep, digits = c(0, 0, 2, 2, 2, 2))
cat("\\resizebox{\\linewidth}{!}{%\n")
print(summary_tab_rep, include.rownames = FALSE, floating = FALSE, comment = FALSE)
cat("}\n")
cat("\\end{minipage}\n")
cat("\\hfill\n")

cat("\\begin{minipage}[t]{0.48\\linewidth}\n")
cat("\\centering\n")
cat("\\textbf{Independents}\\\\[0.5em]\n")
summary_tab_ind <- xtable(tab_ind, digits = c(0, 0, 2, 2, 2, 2))
cat("\\resizebox{\\linewidth}{!}{%\n")
print(summary_tab_ind, include.rownames = FALSE, floating = FALSE, comment = FALSE)
